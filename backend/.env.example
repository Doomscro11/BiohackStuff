# Peptimancer Environment Configuration Example
# Copy to .env and update with your values

# Database Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=peptimancer_production
CORS_ORIGINS=https://your-domain.com

# AI Integration
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# JWT Authentication Configuration
JWT_SECRET=replace_me_with_32bytes_minimum_for_production_security
JWT_ISSUER=peptimancer
JWT_EXPIRES_HOURS=72

# Admin Access Control (comma-separated admin emails, case-insensitive)
ADMIN_EMAILS=founder@yourco.com,cto@yourco.com,admin@peptimancer.ai

# Email Configuration (for production SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourco.com
SMTP_PASS=your_app_password
SMTP_FROM=Peptimancer Admin <noreply@yourco.com>

# Security Configuration
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Feature Flags
ENABLE_DEMO_OTP=true
ENABLE_AUDIT_LOGGING=true
REQUIRE_HTTPS_COOKIES=false
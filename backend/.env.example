# Backend environment template for local development and CI-like smoke testing.
# Copy to backend/.env and replace placeholder values as needed.

MONGO_URL=mongodb://localhost:27017
DB_NAME=peptimancer_dev

JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Temporary backward-compatibility key name. Prefer OPENAI_API_KEY.
EMERGENT_LLM_KEY=

ENABLE_DEMO_OTP=true
DEMO_MODE=true
ENV=development

PARTNER_SIGNING_SECRET=replace-with-a-long-random-secret

STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
REACT_APP_BACKEND_URL=http://localhost:8001
